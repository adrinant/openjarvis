# Copy to ".env" in this folder (same level as package.json).
# OpenJarvis loads this file automatically; do not commit ".env".

AI_GATEWAY_API_KEY=
# Optional:
# OPENJARVIS_AI_MODEL=anthropic/claude-sonnet-4.6

# Voice: browser mic + shortcut; audio goes to ElevenLabs STT.
# TTS uses ElevenLabs (requires VOICE_ID).
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=          # Dashboard → Voices → copy ID (needed for spoken replies via API)
# ELEVENLABS_STT_MODEL=scribe_v2
# ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

# After a voice-sent message, read the assistant reply aloud. Set to 0 to disable.
# OPENJARVIS_VOICE_TTS=1

# Optional wake word (hands-free voice session start, e.g. "hey jarvis").
# Uses browser speech recognition; leave empty to disable.
# VITE_WAKE_WORD=hey jarvis

# Optional: fast double-clap wake (1=enabled, 0/empty=disabled).
# Detects two quick claps and starts voice session.
# VITE_WAKE_DOUBLE_CLAP=1
